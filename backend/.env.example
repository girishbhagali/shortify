# Backend Environment Variables — copy to .env and fill in values
# Never commit .env to git

DATABASE_URL=postgresql://user:password@host:port/db_name

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...

# Set to "production" in your hosting platform
APP_ENV=development

# Public-facing backend URL — used to build clip/zip download URLs
# Example: https://api.shortify.ai
BASE_URL=http://127.0.0.1:8000

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://shortify.ai,https://www.shortify.ai
ALLOWED_ORIGINS=http://localhost:3000

YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret