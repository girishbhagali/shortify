# Backend Environment Variables — copy to .env and fill in values
# Never commit .env to git

DATABASE_URL=

# Set to "production" in your hosting platform
APP_ENV=development

# Public-facing backend URL — used to build clip/zip download URLs
# Example: https://api.shortify.ai
BASE_URL=http://127.0.0.1:8000

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://shortify.ai,https://www.shortify.ai
ALLOWED_ORIGINS=http://localhost:3000

